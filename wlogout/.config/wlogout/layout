{
    "label" : "lock",
    "action" : "~/.config/gtklock/lock.sh",
    "text" : "🔒 Verrouiller",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "niri msg action quit",
    "text" : "🚪 Déconnexion",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "bash -c '~/.config/waybar/caffeine-toggle.sh disable; ~/.config/gtklock/lock.sh & sleep 0.5; systemctl suspend'",
    "text" : "🌙 Mise au repos",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "🔄 Redémarrer",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "⏻ Éteindre",
    "keybind" : "s"
}
