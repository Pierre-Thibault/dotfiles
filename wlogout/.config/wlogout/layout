{
    "label" : "lock",
    "action" : "~/.config/waybar/caffeine-toggle.sh disable && systemctl --user start hypridle.service && loginctl lock-session",
    "text" : "🔒 Verrouiller",
    "keybind" : "l"
}
{
    "label" : "logout",
    "action" : "niri msg action quit",
    "text" : "🚪 Déconnexion",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "~/.config/waybar/caffeine-toggle.sh disable && systemctl --user start hypridle.service && systemctl suspend",
    "text" : "🌙 Mise au repos",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "🔄 Redémarrer",
    "keybind" : "r"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "⏻ Éteindre",
    "keybind" : "s"
}
