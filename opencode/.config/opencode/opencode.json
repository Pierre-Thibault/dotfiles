{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "~/.config/opencode/AGENTS.md",
    "~/secrets/agenda-system-prompt"
  ],
  "permission": {
    "read": {
      "~/secrets/**": "deny",
      "/run/secrets/**": "deny"
    },
    "edit": {
      "~/secrets/**": "deny",
      "/run/secrets/**": "deny"
    },
    "list": {
      "~/secrets/**": "deny",
      "/run/secrets/**": "deny"
    },
    "bash": {
      "**": "ask"
    },
    "task": "ask"
  },
"mcp": {
    "agenda": {
      "type": "local",
      "command": ["/home/pierre/bin/agenda-mcp"]
    }
  },
  "agent": {
    "quick-helper": {
      "mode": "primary",
      "model": "groq/openai/gpt-oss-120b",
      "description": "Handles syntax questions and simple code tasks",
      "temperature": 0.1
    },
    "gpt-oss": {
      "mode": "primary",
      "model": "groq/openai/gpt-oss-120b",
      "description": "GPT OSS 120B on Groq with medium reasoning effort"
    }
  },
  "enabled_providers": ["openai", "groq", "togetherai", "xai"],
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://openai.proxy:4140/v1",
        "apiKey": "proxy"
      }
    },
    "groq": {
      "options": {
        "baseURL": "http://groq.proxy:4140/openai/v1",
        "apiKey": "proxy"
      },
      "models": {
        "openai/gpt-oss-120b": {
          "options": {
            "temperature": 1,
            "max_completion_tokens": 8192,
            "top_p": 1,
            "stream": true,
            "reasoning_effort": "medium",
            "stop": null
          },
          "variant": "default"
        }
      }
    },
    "togetherai": {
      "options": {
        "baseURL": "http://togetherai.proxy:4140",
        "apiKey": "proxy"
      }
    },
    "xai": {
      "options": {
        "baseURL": "http://xai.proxy:4140/v1",
        "apiKey": "proxy"
      }
    }
  }
}