[Unit]
Description=Gammastep - Screen color temperature adjustment
Documentation=man:gammastep(1)
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/run/current-system/sw/bin/gammastep
Restart=always
RestartSec=5

[Install]
WantedBy=graphical-session.target
