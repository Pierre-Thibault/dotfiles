[Unit]
Description=Redland - Screen color temperature adjustment
Documentation=https://github.com/ramojus/redland
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
Environment=WAYLAND_DISPLAY=wayland-1
Environment=XDG_RUNTIME_DIR=/run/user/1000
ExecStart=/run/current-system/sw/bin/redland --lat=45.9 --lon=-74.2 --low=2250
Restart=always
RestartSec=5

[Install]
WantedBy=graphical-session.target
