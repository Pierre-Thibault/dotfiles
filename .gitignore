/wezterm/.config/wezterm/wezterm.lua
/bat/.config/bat/config
/helix/.config/helix/config.toml
# VSCodium - ignore caches but keep settings
**/VSCodium*/Cache/
**/VSCodium*/CachedProfilesData/
**/VSCodium*/User/History/
**/VSCodium*/logs/

config-light.kdl.old

.nobackup

# Systemd services managed by NixOS/home-manager (not dotfiles)
systemd/.config/systemd/user/blueman-applet.service
systemd/.config/systemd/user/tray.target
systemd/.config/systemd/user/graphical-session.target.wants/blueman-applet.service
systemd/.config/systemd/user/graphical-session.target.wants/gammastep.service

# Ignore everything in .claude/
/claude/.claude/*

# But keep CLAUDE.md
!/claude/.claude/CLAUDE.md
